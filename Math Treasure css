body{
  font-family: Arial;
  text-align: center;
  background: linear-gradient(to right, #4facfe, #00f2fe);
  color: white;
}

h1{
  margin-top: 50px;
}

input{
  padding: 8px;
  font-size: 16px;
  border-radius: 5px;
  border: none;
}

button{
  padding: 8px 15px;
  font-size: 16px;
  margin-left: 5px;
  background: gold;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

button:hover{
  background: orange;
}
